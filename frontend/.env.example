# ─── SPINX FRONTEND — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# For Render, set these in Dashboard → Environment → Environment Variables.
# NEVER commit .env to version control.

# ── Google reCAPTCHA v2 ────────────────────────────────────────────────────────
# Obtain from: https://www.google.com/recaptcha/admin
# Use "reCAPTCHA v2 — Checkbox" type.
# Add your Render domain + localhost to Allowed Domains.
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_V2_SITE_KEY_HERE

# ── Google OAuth / Sign-In With Google ────────────────────────────────────────
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web Application type).
# Add https://<your-render-domain>.onrender.com to Authorised JavaScript Origins.
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# ── Backend API URL (leave blank for same-origin / Render, set for local dev) ──
# When running locally with Vite proxy this is not needed (proxy handles /api/*).
# Only set this if you point the frontend at a different backend host.
# VITE_API_URL=http://localhost:5000/api/v1
