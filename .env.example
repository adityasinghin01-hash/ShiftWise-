# ╔════════════════════════════════════════════════════════════╗
# ║  AUTH SYSTEM BACKEND — Environment Variables               ║
# ║  Copy this file to .env and fill in your values            ║
# ╚════════════════════════════════════════════════════════════╝

# ── Server ─────────────────────────────────────────────────
PORT=5001                                    # Server port (Render assigns its own via $PORT)
NODE_ENV=development                         # development | production

# ── Database ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ── JWT Secrets ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Do NOT use human-readable strings like "mysecret123" — use 64 random bytes
JWT_ACCESS_SECRET=                           # 64-byte random hex string
JWT_REFRESH_SECRET=                          # 64-byte random hex string (different from above)
ACCESS_TOKEN_EXPIRES=15m                     # Access token TTL
REFRESH_TOKEN_EXPIRES=7d                     # Refresh token TTL (default, non-rememberMe)

# ── API Key Auth ───────────────────────────────────────────
# Salt used to securely hash developer API keys before storing them in the DB.
# WARNING: Changing this salt will instantly invalidate ALL existing API keys!
API_KEY_SALT=                                # 64-byte random hex string

# ── Webhook Encryption ────────────────────────────────────
# AES-256-GCM key used to encrypt webhook signing secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key will invalidate ALL existing webhook secrets!
WEBHOOK_SECRET_KEY=                          # 32-byte hex string (64 chars)

# ── OTP Hashing ────────────────────────────────────────────
# HMAC secret used to hash 6-digit OTP codes (utils/hashToken.js).
# MED-02 (Wave 1): MUST be different from JWT_ACCESS_SECRET so the OTP and
# JWT keyspaces are separated. Required in production — startup throws if unset.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=                                  # 32-byte hex string

# ── CSRF Protection ────────────────────────────────────────
# HMAC secret for stateless CSRF double-submit tokens (middleware/csrfMiddleware.js).
# MUST be different from JWT secrets — key reuse breaks cryptographic separation.
# Required in production — startup throws if unset.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=                                 # 32-byte hex string

# ── URLs ───────────────────────────────────────────────────
BASE_URL=http://localhost:5001               # Used in verification email links
                                             # In production: https://your-app.onrender.com
CLIENT_URL=http://localhost:3000             # Frontend URL (used in CORS whitelist)

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000         # Comma-separated list of allowed origins
                                             # e.g. https://myapp.com,https://admin.myapp.com

# ── Email (Brevo SMTP) ─────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com               # SMTP server
SMTP_PORT=587                                # 587 for TLS, 465 for SSL
SMTP_USER=                                   # Brevo address
SMTP_PASS=                                   # Brevo password
BREVO_API_KEY=                               # Brevo API Key

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=                            # From Google Cloud Console
                                             # Format: xxxxxxxxxxxx.apps.googleusercontent.com
                                             # ❌ WRONG: GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID=xxx (do NOT duplicate key name)

# ── reCAPTCHA ──────────────────────────────────────────────
RECAPTCHA_SECRET=                            # Server-side secret from Google reCAPTCHA admin
                                             # Test key: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# ── Email Sender Identity ─────────────────────────────────
BREVO_SENDER_EMAIL=                          # "From" email for outgoing emails
ADMIN_EMAIL=                                 # Admin notifications

# ── Rate Limiting (Upstash Redis) ─────────────────────────
UPSTASH_REDIS_REST_URL=                      # From Upstash dashboard
UPSTASH_REDIS_REST_TOKEN=                    # From Upstash dashboard

# ── Test Database ─────────────────────────────────────────
MONGO_URI_TEST=                              # Separate MongoDB for integration tests
